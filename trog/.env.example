# ─────────────────────────────────────────────
# LLM_MODE:
#   "wrapper"   = OpenAI 호환 엔드포인트 (NVIDIA NIM, 로컬 프록시, OpenRouter 등)
#   "anthropic" = Anthropic 공식 API (Claude 직접 호출)
# ─────────────────────────────────────────────
LLM_MODE=wrapper

# ── wrapper 모드: 다중 공급자 릴레이 (OpenAI 호환 엔드포인트) ──
# WRAPPER_URL(=1번), WRAPPER2_*, WRAPPER3_* ... 번호 순으로 파싱. URL 이 없으면 중단, 최대 5개.
# 공급자 순서대로, 각 공급자 안에서 [MODEL]+FALLBACKS 순으로 시도.
# → 1순위 공급자가 한도 소진(429)/장애면 다음 공급자로 자동 릴레이.

# ── 공급자 1 (주력): Google Gemini — 한국어 품질 담당 (OpenAI 호환 엔드포인트) ──
# 무료 티어: 분당 10회 / 하루 1,500회 수준. 한도 소진 시 공급자 2로 자동 릴레이.
WRAPPER_URL=https://generativelanguage.googleapis.com/v1beta/openai/
WRAPPER_MODEL=gemini-2.5-flash
WRAPPER_FALLBACKS=gemini-2.5-flash-lite
WRAPPER_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ── 공급자 2 (예비): NVIDIA NIM — Gemini 한도 소진/장애 시 ──
WRAPPER2_URL=https://integrate.api.nvidia.com/v1
WRAPPER2_MODEL=qwen/qwen3.5-122b-a10b
WRAPPER2_FALLBACKS=meta/llama-3.3-70b-instruct,google/gemma-4-31b-it
WRAPPER2_API_KEY=nvapi-REPLACE_WITH_YOUR_KEY

# (공급자 3 추가 예시 — 로컬 claude-code-openai-wrapper)
# WRAPPER3_URL=http://localhost:8000/v1
# WRAPPER3_MODEL=claude-sonnet-4-6
# WRAPPER3_API_KEY=sk-dummy

# ── anthropic 모드 설정 (백업/비교용) ──
# https://console.anthropic.com/ 에서 발급받은 sk-ant-... 키
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 게임 서버 포트 (래퍼와 8000 충돌 방지) ──
GAME_PORT=8080

# ── LLM 호출 타임아웃 (초) ──
# 90초 안에 응답 못 하면 다음 fallback 모델로 자동 우회.
LLM_TIMEOUT_SEC=90

# ── DM 응답 스트리밍 (기본 OFF, 권장 OFF) ──
# LLM_STREAMING=1 로 켜면 부분 응답을 dm_chunk 로 흘려보내지만, 스트리밍 중 실패 시
# 다음 공급자 릴레이가 불가해진다(부분 텍스트가 이미 전송됨). 429 한도소진 릴레이가 이 게임의
# 핵심 안정성 장치라 스트리밍과 상충 → OFF 유지. 대기자 진행표시는 dm_pending 이벤트로 대체.
# LLM_STREAMING=0
